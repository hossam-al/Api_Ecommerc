{
    "name": "hossam/api-ecommerc",
    "description": "Laravel API project (minimal composer.json)",
    "type": "project",
    "require": {
        "php": "^8.2",
        "cloudinary-labs/cloudinary-laravel": "^3.0",
        "laravel/framework": "^11.0 || ^12.0",
        "laravel/pail": "1.2",
        "laravel/sail": "^1.57",
        "laravel/sanctum": "^4.3",
        "laravel/tinker": "^3.0",
        "nunomaduro/collision": "^8.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require-dev": {
        "fakerphp/faker": "^1.24"
    }
}
