{
    "name": "hossam/api-ecommerc",
    "description": "Laravel API project (minimal composer.json)",
    "type": "project",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
